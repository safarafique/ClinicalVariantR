^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.cursorignore$
^\.gitignore$
# Development trees (non-R assets ship via inst/extdata and inst/shinyapp).
# Use trailing "/" so paths like data/foo.tsv match; "^data$" only matches the dir name.
^data/
^config/
^www/
^scripts/
^logs/
^results/
^standalone/
^ClinicalVariantR$
^ClinicalVariantR\.Rcheck$
^ClinicalVariantR\.BiocCheck$
^.*\.tar\.gz$
^GExPipe\.Rmd$
^CODEBASE_MAP\.md$
^BIOCONDUCTOR\.md$
^app\.R$
^global\.R$
^global_cli\.R$
^server\.R$
^ui\.R$
^R/shiny/
^inst/Bioconductor/
^vignettes/images/
^renv/library$
^renv/staging$
